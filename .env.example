# PitchMint API keys config
# Rename this file to .env.local for local Next.js development

# 1. Gemini API (Primary Engine)
# Get a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Fallback APIs (used if Gemini fails or is omitted)
# Groq Console (Llama models): https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Grok / xAI Console (Grok models): https://console.x.ai/
GROK_API_KEY=your_grok_api_key_here

# 3. Supabase Integration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# 4. Stripe Billing
# Get keys from Stripe Dashboard > Developers > API Keys (use Test Mode keys for dev)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# 5. Lemon Squeezy Billing (Active default)
# Step 1: Sign up at https://app.lemonsqueezy.com and create a store.
# Step 2: Create a product with two variants (Freelancer $12, Studio $29).
# Step 3: Copy the keys below from:
#   - API Key:     Settings > API > New API Key
#   - Store ID:    Settings > General (number in the URL or store slug)
#   - Variant IDs: Products > your product > Variants (the numeric ID in the URL)
#   - Webhook:     Settings > Webhooks > Add endpoint (URL: https://yourdomain/api/lemonsqueezy/webhook, event: order_created)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=        # OPTIONAL — auto-fetched from your API key if left blank
LEMONSQUEEZY_WEBHOOK_SECRET=
# Variant IDs for each credit pack (numeric, visible in LS dashboard URLs)
NEXT_PUBLIC_LS_FREELANCER_VARIANT_ID=
NEXT_PUBLIC_LS_STUDIO_VARIANT_ID=

# 6. Billing Provider Toggle
# Set to 'stripe' or 'lemonsqueezy' to switch the active payment gateway
NEXT_PUBLIC_BILLING_PROVIDER=lemonsqueezy
